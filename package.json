{
  "name": "brain-game",
  "version": "1.0.0",
  "description": "Flow State Sanctuary brain training prototype",
  "main": "main.js",
  "scripts": {
    "build:tailwind": "tailwindcss -i ./tailwind.input.css -o ./tailwind.generated.css --minify",
    "prestart": "node build-if-changed.js",
    "start": "electron .",
    "predev": "node build-if-changed.js",
    "dev": "electron .",
    "rebuild-native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "pnpm run rebuild-native",
    "build": "pnpm run build:tailwind && pnpm exec electron-builder",
    "build:win": "pnpm run build:tailwind && pnpm exec electron-builder --win"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "electron": "^31.3.1",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "build": {
    "appId": "com.zeroz.braingame",
    "productName": "Brain_game",
    "directories": {
      "output": "dist"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "renderer.js",
      "styles.css",
      "tailwind.generated.css",
      "src/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": false
    }
  }
}
