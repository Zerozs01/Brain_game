{
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/.git": true,
    "**/dist": true,
    "**/out": true,
    "**/build": true,
    "**/release": true,
    "**/.next": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/build/**": true,
    "**/release/**": true
  },
  "search.followSymlinks": false
}
